# iFlow CLI 忽略规则
# 这个文件告诉 iFlow CLI 在处理项目时应该忽略哪些文件和目录

# 编译输出
target/
*.class
*.jar
*.war
*.nar
*.ear

# Maven 包装器
.mvn/
mvnw
mvnw.cmd

# IDE 配置文件
.idea/
*.iml
*.ipr
*.iws
.vscode/
.settings/
.project
.classpath

# 操作系统文件
.DS_Store
Thumbs.db

# 日志文件
*.log
logs/

# 敏感配置（token 存储）
.config/

# Quarkus 配置
.quarkus/

# Git 目录
.git/

# Python 字节码
__pycache__/
*.py[cod]
*$py.class
*.pyo

# 临时文件
*.tmp
*.temp
*.swp
*.swo
*~

# 测试输出和覆盖率报告
test-output/
coverage/
.nyc_output/
